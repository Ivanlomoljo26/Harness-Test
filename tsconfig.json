{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "@playwright/test"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "apps/**/*.ts",
    "config/**/*.ts",
    "harness/**/*.ts",
    "wallet/**/*.ts",
    "playwright.config.ts"
  ]
}
