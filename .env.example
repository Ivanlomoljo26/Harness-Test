# Primary network for local and CI runs.
E2E_NETWORK=testnet

# App selection: all, zoroswap, or qash. qash is the lowest-friction default for new users.
E2E_APP=qash

# Wallet repo and testnet extension build.
WALLET_REPO_PATH=../wallet
WALLET_EXTENSION_PATH_TESTNET=.wallet-builds/testnet/chrome_unpacked
# Required only for wallet-backed apps/runs. Keep this local.
WALLET_PASSWORD=
WALLET_SETUP_MODE=create

# For ZoroSwap connect-only smoke tests, WALLET_SETUP_MODE=create creates an ephemeral wallet.
# Qash account-onboarding smoke does not use the Miden wallet.
# For funded swap/payment tests, provide either TEST_ACCOUNT_SEED or WALLET_USER_DATA_DIR.
# TEST_ACCOUNT_SEED should be a 12+ word seed phrase.
TEST_ACCOUNT_SEED=
WALLET_USER_DATA_DIR=

# Prepared app auth profile for Qash Google/Para login.
# Create it with: yarn qash:profile
QASH_AUTH_USER_DATA_DIR=
# Optional: select this already-signed-in Google account when preparing the profile.
QASH_GOOGLE_ACCOUNT_EMAIL=
# Optional: assert this email is present on authenticated Qash pages.
QASH_AUTH_ACCOUNT_EMAIL=
# Optional: connect authenticated Qash tests to an already-launched Chrome CDP endpoint.
QASH_AUTH_CDP_ENDPOINT=
# APP_AUTH_USER_DATA_DIR can be used as a generic fallback for app-auth profiles.
APP_AUTH_USER_DATA_DIR=
# APP_AUTH_CDP_ENDPOINT can be used as a generic fallback for app-auth CDP endpoints.
APP_AUTH_CDP_ENDPOINT=

# Qash Payroll stateful regression gates.
# Defaults keep Payroll read-only. Set only on a funded test account with safe test data.
QASH_FAUCET_REQUEST_TIMEOUT_MS=180000
QASH_PENDING_FAUCET_RECEIVE_TIMEOUT_MS=300000
QASH_FAUCET_SETTLEMENT_TIMEOUT_MS=300000
QASH_ACCOUNT_DIRECT_FUNDING_TIMEOUT_MS=15000
QASH_FILL_PAYROLL_FORM=false
QASH_CREATE_PAYROLL=false
QASH_COMPLETE_PAYROLL_TRANSACTION=false
QASH_CREATE_PAYROLL_CONTACT=false
QASH_CREATE_PAYROLL_CONTACT_GROUP=false
QASH_PAYROLL_EMPLOYEE_NAME=
QASH_PAYROLL_EMPLOYEE_EMAIL=
QASH_PAYROLL_EMPLOYEE_WALLET_ADDRESS=
QASH_PAYROLL_CONTACT_GROUP=
QASH_PAYROLL_NETWORK=Miden Testnet
QASH_PAYROLL_TOKEN=QASH
QASH_PAYROLL_DURATION_MONTHS=1
QASH_PAYROLL_MONTHLY_AMOUNT=
QASH_PAYROLL_PAY_DAY=1
QASH_PAYROLL_ITEM_DESCRIPTION=
QASH_PAYROLL_NOTE=

# Qash continuous product journey:
# account creation -> faucet funding/sign/execute -> balance -> contact -> Payroll -> Invoice -> Payment Link.
# Prepare profile with: QASH_AUTH_USER_DATA_DIR=.auth/qash yarn qash:profile
# Run with: yarn qash-platform-e2e
QASH_PLATFORM_JOURNEY=false
QASH_PLATFORM_CONTACT_WALLET_ADDRESS=
QASH_PLATFORM_ACCOUNT_NAME=
QASH_PLATFORM_ACCOUNT_DESCRIPTION=
QASH_PLATFORM_CONTACT_NAME=
QASH_PLATFORM_CONTACT_EMAIL=
QASH_PLATFORM_CONTACT_GROUP=
QASH_PLATFORM_CREATE_CONTACT_GROUP=false
QASH_PLATFORM_PAYROLL_NETWORK=Miden Testnet
QASH_PLATFORM_PAYROLL_TOKEN=QASH
QASH_PLATFORM_PAYROLL_DURATION_MONTHS=1
QASH_PLATFORM_PAYROLL_MONTHLY_AMOUNT=
QASH_PLATFORM_PAYROLL_PAY_DAY=1
QASH_PLATFORM_PAYROLL_ITEM_DESCRIPTION=
QASH_PLATFORM_PAYROLL_NOTE=
QASH_PLATFORM_INVOICE_CLIENT_NAME=
QASH_PLATFORM_INVOICE_CLIENT_EMAIL=
QASH_PLATFORM_INVOICE_CLIENT_WALLET_ADDRESS=
QASH_PLATFORM_INVOICE_NETWORK=Miden Testnet
QASH_PLATFORM_INVOICE_TOKEN=QASH
QASH_PLATFORM_INVOICE_AMOUNT=
QASH_PLATFORM_INVOICE_DUE_DAY=
QASH_PLATFORM_INVOICE_ITEM_DESCRIPTION=
QASH_PLATFORM_INVOICE_NOTE=
QASH_PLATFORM_PAYMENT_LINK_TITLE=
QASH_PLATFORM_PAYMENT_LINK_AMOUNT=
QASH_PLATFORM_PAYMENT_LINK_DESCRIPTION=
QASH_PLATFORM_PAYMENT_LINK_ACCOUNT_NAME=
QASH_PLATFORM_PAYMENT_LINK_NETWORK=Miden Testnet
QASH_PLATFORM_PAYMENT_LINK_TOKEN=QASH
QASH_PLATFORM_JOURNEY_TIMEOUT_MS=900000
QASH_PLATFORM_ACCOUNT_POOL_SIZE=3
QASH_PLATFORM_MAX_ACCOUNT_COUNT=
QASH_PLATFORM_ALLOW_ACCOUNT_OVER_CAP=false

# Qash stress:
# actor-a setup -> faucet monitor -> repeated Payroll/Invoice mixed platform mutations.
# Payment Link creation and Actor A/B public Payment Link settlement are disabled by
# default until the upstream Qash Payment Link route is healthy again.
# Prepare actor-a profile with: QASH_AUTH_USER_DATA_DIR=.auth/qash/actor-a yarn qash:profile
# Run with: yarn qash-stress
QASH_STRESS=false
QASH_ACTOR_B_WALLET_ADDRESS=
QASH_STRESS_RECEIVER_WALLET_ADDRESS=
QASH_STRESS_RECEIVER_NAME=
QASH_STRESS_RECEIVER_EMAIL=
QASH_STRESS_CONTACT_GROUP=
QASH_STRESS_CREATE_CONTACT_GROUP=false
QASH_STRESS_LOOPS=
QASH_STRESS_FAILURE_BUDGET=0
QASH_STRESS_PAYMENT_AMOUNT=
QASH_STRESS_INVOICE_AMOUNT=
QASH_STRESS_PAYMENT_LINK_AMOUNT=
QASH_STRESS_INCLUDE_MIXED_PLATFORM=true
QASH_STRESS_INCLUDE_MONEY_MOVEMENT=false
QASH_STRESS_INCLUDE_PAYROLL=true
QASH_STRESS_INCLUDE_INVOICE=true
QASH_STRESS_INCLUDE_PAYMENT_LINK=false
QASH_STRESS_SKIP_FAUCET_IF_FUNDED=false
QASH_STRESS_EXISTING_FUNDING_TIMEOUT_MS=30000
QASH_STRESS_ATTEMPT_PENDING_TRANSACTIONS=false
QASH_STRESS_COMPLETE_PENDING_TRANSACTIONS=false
QASH_STRESS_ACCOUNT_POOL_SIZE=3
QASH_STRESS_ALLOW_ACCOUNT_OVER_CAP=false
QASH_STRESS_TIMEOUT_MS=1800000
QASH_STRESS_MONEY_MOVEMENT_DIRECTION=bidirectional
QASH_STRESS_MONEY_MOVEMENT_AMOUNT=
QASH_STRESS_MONEY_MOVEMENT_TIMEOUT_MS=1800000
QASH_STRESS_MONEY_MOVEMENT_PAYMENT_TIMEOUT_MS=300000
QASH_STRESS_MONEY_MOVEMENT_RECEIVE_TIMEOUT_MS=300000
QASH_STRESS_MONEY_MOVEMENT_CREATE_MISSING_ACCOUNTS=false

# Qash stress compatibility aliases:
QASH_DURABILITY_STRESS=false
QASH_DURABILITY_RECEIVER_WALLET_ADDRESS=
QASH_DURABILITY_RECEIVER_NAME=
QASH_DURABILITY_RECEIVER_EMAIL=
QASH_DURABILITY_CONTACT_GROUP=
QASH_DURABILITY_CREATE_CONTACT_GROUP=false
QASH_DURABILITY_LOOPS=
QASH_DURABILITY_PAYMENT_LOOPS=
QASH_DURABILITY_FAILURE_BUDGET=0
QASH_DURABILITY_PAYMENT_AMOUNT=
QASH_DURABILITY_INVOICE_AMOUNT=
QASH_DURABILITY_PAYMENT_LINK_AMOUNT=
QASH_DURABILITY_INCLUDE_PAYROLL=true
QASH_DURABILITY_INCLUDE_INVOICE=true
QASH_DURABILITY_INCLUDE_PAYMENT_LINK=false
QASH_DURABILITY_ATTEMPT_PENDING_TRANSACTIONS=false
QASH_DURABILITY_COMPLETE_PENDING_TRANSACTIONS=false
QASH_DURABILITY_ACCOUNT_POOL_SIZE=3
QASH_DURABILITY_ALLOW_ACCOUNT_OVER_CAP=false
QASH_DURABILITY_TIMEOUT_MS=1800000

# Qash Actor A/B money movement:
# actor creates Payment Link -> other actor pays from its Miden extension wallet -> receiver claims receive note.
# Run with: yarn test:e2e:testnet:qash:money-movement
QASH_MONEY_MOVEMENT=false
QASH_MONEY_MOVEMENT_LOOPS=
QASH_MONEY_MOVEMENT_DIRECTION=bidirectional
QASH_MONEY_MOVEMENT_AMOUNT=
QASH_MONEY_MOVEMENT_NETWORK=Miden Testnet
QASH_MONEY_MOVEMENT_TOKEN=QASH
QASH_MONEY_MOVEMENT_TIMEOUT_MS=1800000
QASH_MONEY_MOVEMENT_PAYMENT_TIMEOUT_MS=300000
QASH_MONEY_MOVEMENT_RECEIVE_TIMEOUT_MS=300000
QASH_MONEY_MOVEMENT_ACCOUNT_POOL_SIZE=3
QASH_MONEY_MOVEMENT_CREATE_MISSING_ACCOUNTS=false
QASH_MONEY_MOVEMENT_ALLOW_ACCOUNT_OVER_CAP=false
QASH_PAYER_WALLET_SETUP_MODE=
QASH_PAYER_TEST_ACCOUNT_SEED=
QASH_PAYER_WALLET_USER_DATA_DIR=
QASH_PAYER_WALLET_BALANCE_TIMEOUT_MS=120000
QASH_ACTOR_A_EMAIL=
QASH_ACTOR_A_ACCOUNT_ID=
QASH_ACTOR_A_WALLET_ADDRESS=
QASH_ACTOR_A_PROFILE_DIR=.auth/qash/actor-a
QASH_ACTOR_A_PAYER_WALLET_SETUP_MODE=
QASH_ACTOR_A_PAYER_TEST_ACCOUNT_SEED=
QASH_ACTOR_A_PAYER_WALLET_USER_DATA_DIR=
QASH_ACTOR_A_SOCIAL_PAYMENT=false
QASH_ACTOR_A_SOCIAL_PAYMENT_PAY=true
QASH_ACTOR_A_SOCIAL_PAYMENT_TIMEOUT_MS=300000
QASH_ACTOR_B_EMAIL=
QASH_ACTOR_B_ACCOUNT_ID=
QASH_ACTOR_B_WALLET_ADDRESS=
QASH_ACTOR_B_PROFILE_DIR=.auth/qash/actor-b
QASH_ACTOR_B_PAYER_WALLET_SETUP_MODE=
QASH_ACTOR_B_PAYER_TEST_ACCOUNT_SEED=
QASH_ACTOR_B_PAYER_WALLET_USER_DATA_DIR=

# Qash account-backed feature checks. Requires a prepared profile with at least one multisig account.
QASH_REQUIRE_FEATURE_CREATE_ACTIONS=false

# Qash Invoice regression gates.
# Form fill can create a fresh Client contact; actual invoice creation is experimental until live-verified.
QASH_FILL_INVOICE_FORM=false
QASH_CREATE_INVOICE=false
QASH_CREATE_INVOICE_WIZARD_EXPERIMENTAL=false
QASH_CREATE_INVOICE_CLIENT=false
QASH_INVOICE_CLIENT_NAME=
QASH_INVOICE_CLIENT_EMAIL=
QASH_INVOICE_CLIENT_WALLET_ADDRESS=
QASH_INVOICE_NETWORK=Miden Testnet
QASH_INVOICE_TOKEN=QASH
QASH_INVOICE_AMOUNT=
QASH_INVOICE_DUE_DAY=
QASH_INVOICE_ITEM_DESCRIPTION=
QASH_INVOICE_NOTE=

# Qash Payment Link regression gates.
# Defaults stop before submitting; creation is experimental until live-verified.
QASH_FILL_PAYMENT_LINK_FORM=false
QASH_CREATE_PAYMENT_LINK=false
QASH_CREATE_PAYMENT_LINK_EXPERIMENTAL=false
QASH_PAYMENT_LINK_TITLE=
QASH_PAYMENT_LINK_AMOUNT=
QASH_PAYMENT_LINK_DESCRIPTION=
QASH_PAYMENT_LINK_NETWORK=Miden Testnet
QASH_PAYMENT_LINK_TOKEN=QASH

# Optional Windows Chrome profile controls for:
# yarn test:e2e:testnet:qash:auth:windows-profile
QASH_WINDOWS_CHROME_EXE=
QASH_WINDOWS_CHROME_USER_DATA_DIR=
QASH_WINDOWS_CHROME_PROFILE_DIRECTORY=
QASH_WINDOWS_CHROME_DEBUG_PORT=
QASH_WINDOWS_CHROME_DEBUG_ADDRESS=
QASH_WINDOWS_CHROME_CONNECT_HOST=
QASH_WINDOWS_CDP_PROXY_PORT=
QASH_WINDOWS_TEMP_DIR=

# Network-specific app URLs.
ZOROSWAP_URL_TESTNET=https://app.zoroswap.com/
QASH_URL_TESTNET=https://app.qash.finance/

# Optional generic URL override for single-network experiments only.
ZOROSWAP_URL=
QASH_URL=

# Optional selector overrides for unstable app UIs.
ZOROSWAP_CONNECT_SELECTOR=
QASH_LOGIN_SELECTOR=

# Debug controls.
HEADLESS=false
E2E_KEEP_BROWSER_ON_FAILURE=false
